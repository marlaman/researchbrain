{
  "components": [
    {
      "id": "chat_2",
      "provider": "chat",
      "name": "Chat",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": {
        "position": {
          "x": -250,
          "y": 570
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "agent_deepagent_1",
      "provider": "agent_deepagent",
      "name": "Deep Agent",
      "config": {
        "default": {
          "advanced_mode": false,
          "instructions": [
            "You are an incremental research checker. The user message includes a topic, EXISTING XTRACE MEMORY (beliefs we already store), and KNOWN SOURCES (URLs already saved). Your job is to find ONLY genuinely NEW developments — not a full re-research.",
            "1) HTTP tool: GET https://export.arxiv.org/api/query?search_query=all:TOPIC&max_results=10&sortBy=submittedDate (URL-encode the topic). Prefer recent submissions.",
            "2) Exa search: query for recent news and research on the topic (include terms like 'latest', '2025', '2026' when appropriate).",
            "3) Firecrawl: scrape 2–4 of the most relevant NEW URLs not already in KNOWN SOURCES.",
            "Compare everything you find against EXISTING XTRACE MEMORY and KNOWN SOURCES. If nothing meaningfully new, set has_new_info to false.",
            "Never invent URLs. Return ONLY valid JSON — no markdown fences.",
            "OUTPUT: { topic, has_new_info, significance, update_summary, new_sources: [{ id, title, url, type, snippet, date }], new_claims: [{ text, source_ids }], reason_no_push } where significance is one of: none, low, high. reason_no_push explains when has_new_info is false."
          ]
        }
      },
      "ui": {
        "position": {
          "x": 70,
          "y": 580
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "chat_2"
        }
      ]
    },
    {
      "id": "response_answers_2",
      "provider": "response_answers",
      "name": "Return Answers",
      "config": {
        "laneName": "answers"
      },
      "ui": {
        "position": {
          "x": 260,
          "y": 580
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "answers",
          "from": "agent_deepagent_1"
        }
      ]
    },
    {
      "id": "llm_openai_1",
      "provider": "llm_openai",
      "name": "OpenAI",
      "config": {
        "profile": "openai-4o",
        "openai-4o": {
          "apikey": "${ROCKETRIDE_OPENAI_KEY}",
          "modelSource": ""
        },
        "parameters": {}
      },
      "ui": {
        "position": {
          "x": -150,
          "y": 930
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "llm",
          "from": "agent_deepagent_1"
        }
      ]
    },
    {
      "id": "tool_exa_search_1",
      "provider": "tool_exa_search",
      "name": "Exa Search",
      "config": {
        "type": "tool_exa_search",
        "apikey": "${ROCKETRIDE_EXA_KEY}",
        "numResults": 10,
        "useAutoprompt": true,
        "searchType": "auto",
        "includeText": true
      },
      "ui": {
        "position": {
          "x": -20,
          "y": 1020
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_deepagent_1"
        }
      ]
    },
    {
      "id": "tool_firecrawl_1",
      "provider": "tool_firecrawl",
      "name": "Firecrawl",
      "config": {
        "type": "tool_firecrawl",
        "apikey": "${ROCKETRIDE_FIRECRAWL_KEY}"
      },
      "ui": {
        "position": {
          "x": 200,
          "y": 1020
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_deepagent_1"
        }
      ]
    },
    {
      "id": "tool_http_request_1",
      "provider": "tool_http_request",
      "name": "HTTP Request",
      "config": {
        "type": "tool_http_request",
        "allowGET": true,
        "allowPOST": false,
        "allowPUT": false,
        "allowPATCH": false,
        "allowDELETE": false,
        "allowHEAD": false,
        "allowOPTIONS": false,
        "urlWhitelist": [
          {
            "whitelistPattern": "^https://export\\.arxiv\\.org/.*"
          }
        ],
        "rateLimitPerSecond": 10,
        "rateLimitPerMinute": 100,
        "maxConcurrentRequests": 5
      },
      "ui": {
        "position": {
          "x": 370,
          "y": 1020
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_deepagent_1"
        }
      ]
    }
