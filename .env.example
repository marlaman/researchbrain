# Butterbase (frontend)
VITE_BUTTERBASE_APP_ID=
VITE_BUTTERBASE_API_URL=https://api.butterbase.ai
VITE_BUTTERBASE_SERVICE_KEY=

# Local Rocket Ride — auto-discovers port + token when pipeline is Run in Cursor
ROCKETRIDE_PIPE=./topic-research.pipe
ROCKETRIDE_CHECK_PIPE=./topic-research-check.pipe
# Optional overrides (usually leave unset — tokens rotate each Run):
# ROCKETRIDE_URI=http://localhost:50526
# ROCKETRIDE_PRIVATE_TOKEN=tk_...

# Xtrace memory (local backend after research completes)
XTRACE_API_KEY=
XTRACE_ORG_ID=
# XTRACE_API_URL=https://api.production.xtrace.ai
# Xtrace user_id = logged-in user performing research/check (session.user.id from the UI).
# conv_id is topic-<name> (e.g. topic-sky) scoped per user_id in Xtrace.
